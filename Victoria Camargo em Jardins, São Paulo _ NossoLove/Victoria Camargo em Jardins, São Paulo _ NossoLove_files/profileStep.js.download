/**
 * ProfileStepUI - Módulo JavaScript para máscara de telefone WhatsApp
 * Gerencia a máscara de telefone com tratamento anti-latência (sem round-trip Blazor).
 * Suporta números brasileiros e internacionais (com +).
 */
(function() {
    const bindings = [];

    function setCaret(el, pos) {
        if (el.setSelectionRange) {
            el.setSelectionRange(pos, pos);
        }
    }

    function onlyDigits(s) {
        return (s || "").replace(/\D+/g, "");
    }

    /**
     * Formata número brasileiro (sem +).
     * Até 10 dígitos: (XX) XXXX-XXXX
     * 11 dígitos: (XX) X XXXX-XXXX
     */
    function formatBrazilian(d) {
        if (d.length > 11) d = d.slice(0, 11);
        if (d.length === 0) return "";
        if (d.length <= 2) return "(" + d;
        if (d.length <= 6) return "(" + d.slice(0, 2) + ") " + d.slice(2);
        if (d.length <= 10) return "(" + d.slice(0, 2) + ") " + d.slice(2, 6) + "-" + d.slice(6);
        return "(" + d.slice(0, 2) + ") " + d.slice(2, 3) + " " + d.slice(3, 7) + "-" + d.slice(7);
    }

    /**
     * Formata número internacional (com +).
     * DDI 55 (Brasil): +55 (XX) X XXXX-XXXX
     * Outros: +DDI XXXX XXXX ...
     */
    function formatInternational(d) {
        if (d.length === 0) return "+";

        // DDI brasileiro (+55)
        if (d.slice(0, 2) === "55" && d.length >= 3) {
            var br = d.slice(2);
            if (br.length > 11) br = br.slice(0, 11);
            if (br.length === 0) return "+55";
            if (br.length <= 2) return "+55 (" + br;
            var dd = br.slice(0, 2);
            if (br.length <= 10) {
                var rest = br.slice(2);
                if (rest.length > 4) rest = rest.slice(0, 4) + "-" + rest.slice(4);
                return "+55 (" + dd + ") " + rest;
            } else {
                return "+55 (" + dd + ") " + br.slice(2, 3) + " " + br.slice(3, 7) + "-" + br.slice(7);
            }
        }

        // Internacional genérico (E.164 max 15 dígitos)
        if (d.length > 15) d = d.slice(0, 15);

        var ddiLen;
        if (d.charAt(0) === "1" && d.charAt(1) !== "0") ddiLen = 1;
        else if (d.length >= 3 && d.charAt(0) === "2") ddiLen = 3;
        else ddiLen = Math.min(2, d.length);

        var ddi = d.slice(0, ddiLen);
        var rest2 = d.slice(ddiLen);

        if (rest2.length === 0) return "+" + ddi;

        var out = "+" + ddi + " ";
        for (var i = 0; i < rest2.length; i++) {
            if (i > 0 && i % 4 === 0) out += " ";
            out += rest2.charAt(i);
        }
        return out;
    }

    /**
     * Formata o telefone detectando automaticamente se é internacional (começa com +).
     */
    function formatPhone(raw) {
        var trimmed = raw.trim();
        var hasPlus = trimmed.charAt(0) === "+";
        var d = onlyDigits(raw);

        if (hasPlus) return formatInternational(d);
        return formatBrazilian(d);
    }

    /**
     * Aplica a máscara no input mantendo a posição correta do cursor.
     */
    function maskInput(el) {
        var start = el.selectionStart || 0;
        var before = el.value;
        var formatted = formatPhone(before);
        el.value = formatted;

        // Calcula a nova posição do cursor
        var map = new Map();
        var di = 0;
        for (var i = 0; i < formatted.length; i++) {
            if (/\d/.test(formatted.charAt(i))) {
                map.set(di, i);
                di++;
            }
        }
        // Conta quantos dígitos havia antes do cursor
        var prevDigitsBeforeCaret = onlyDigits(before.slice(0, start)).length;

        // Se o usuário digitou '+', posicionar após o '+'
        var hadPlusBefore = before.trim().charAt(0) === "+";
        var hasPlusNow = formatted.charAt(0) === "+";

        var newPos;
        if (hasPlusNow && prevDigitsBeforeCaret === 0) {
            // Cursor estava antes de qualquer dígito mas há '+', posicionar após '+'
            newPos = 1;
        } else if (map.has(prevDigitsBeforeCaret)) {
            newPos = map.get(prevDigitsBeforeCaret);
        } else if (map.has(prevDigitsBeforeCaret - 1)) {
            newPos = map.get(prevDigitsBeforeCaret - 1) + 1;
        } else {
            newPos = formatted.length;
        }
        newPos = Math.min(formatted.length, Math.max(0, newPos));
        setCaret(el, newPos);
    }

    function onInput(e) {
        maskInput(e.target);
    }

    /**
     * Vincula a máscara a um elemento input pelo id.
     */
    function bindInput(id) {
        var el = document.getElementById(id);
        if (!el) return;

        // Verifica se já está vinculado
        for (var i = 0; i < bindings.length; i++) {
            if (bindings[i].id === id) return;
        }

        el.addEventListener('input', onInput);
        bindings.push({ id: id, el: el });

        // Aplica a máscara no valor inicial
        if (el.value) {
            maskInput(el);
        }
    }

    /**
     * Inicializa a máscara para o campo padrão 'whatsapp-input' (ProfileStep/Onboarding).
     */
    function init() {
        bindInput('whatsapp-input');
    }

    /**
     * Inicializa a máscara para o campo do ProfileEdit.
     */
    function initEdit() {
        bindInput('whatsapp-input-edit');
    }

    /**
     * Remove todos os event listeners e limpa o estado.
     */
    function dispose() {
        for (var i = 0; i < bindings.length; i++) {
            var b = bindings[i];
            if (b.el) {
                b.el.removeEventListener('input', onInput);
            }
        }
        bindings.length = 0;
    }

    /**
     * Retorna o valor atual de um campo WhatsApp pelo id.
     */
    function getValue(id) {
        var el = document.getElementById(id || 'whatsapp-input');
        return el ? el.value : "";
    }

    /**
     * Retorna o valor do campo WhatsApp padrão (retrocompatibilidade).
     */
    function getWhatsAppValue() {
        return getValue('whatsapp-input');
    }

    /**
     * Retorna o valor do campo WhatsApp do ProfileEdit.
     */
    function getWhatsAppEditValue() {
        return getValue('whatsapp-input-edit');
    }

    // Expõe a API globalmente
    window.ProfileStepUI = { init, initEdit, dispose, getWhatsAppValue, getWhatsAppEditValue, getValue };
})();
